# ---------- Required on Render ----------
# Render will provide this automatically if you attach a Render Postgres database.
DATABASE_URL=

# Used to sign JWTs (set a long random string in Render env vars)
JWT_SECRET=

# Comma-separated list of allowed browser origins for CORS, e.g.
# CORS_ORIGINS=https://your-app.onrender.com,https://your-static-site.onrender.com
# Use '*' to allow all (not recommended for production)
CORS_ORIGINS=

# Where users should be sent for email verification links (your client URL)
APP_BASE_URL=

# ---------- Optional ----------
# If 'false', signup returns a JWT immediately without email verification.
REQUIRE_EMAIL_VERIFICATION=true

# Admin-only teacher creation (optional)
ADMIN_CREATE_TEACHER_KEY=

# SMTP settings (required only if REQUIRE_EMAIL_VERIFICATION=true)
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
